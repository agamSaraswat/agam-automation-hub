# Copy to .env and fill values for services you use.

# Required for Claude features
ANTHROPIC_API_KEY=

# LinkedIn (optional, required only for publish)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:
LINKEDIN_TOKEN_SET_DATE=2026-01-01

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail OAuth (optional)
GMAIL_CREDENTIALS_PATH=credentials.json

# Web API / local overrides
WEB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIMEZONE=America/New_York
DAILY_JOB_LIMIT=
